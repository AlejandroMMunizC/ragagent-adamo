# ---------------------------------------------------------------------------
# RAGAGENT - environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` (same folder) and fill in the real values.
# `.env` is git-ignored, so secrets stay on your machine.
# ---------------------------------------------------------------------------

# REQUIRED - OpenAI API key used by the LLM and the embeddings client.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# OPTIONAL - Gmail SMTP credentials, used by the `send_email` tool only.
# Use a Gmail App Password (NOT your normal password). Guide:
# https://support.google.com/accounts/answer/185833
GMAIL_USER=your.address@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# OPTIONAL - model overrides (sensible defaults are used if omitted)
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# OPTIONAL - retrieval knobs
CHUNK_SIZE=500
CHUNK_OVERLAP=50
DEFAULT_K=5
